PORT=3000

# MercadoPago
MP_ACCESS_TOKEN=tu_access_token_de_mercadopago

# Webhook URL (usar UNA de las dos según el entorno)
# Local: usar ngrok para exponer el servidor local a MercadoPago
NGROK_URL=https://tu-subdominio.ngrok-free.dev
# Producción: URL del backend en Render (descomentar y quitar NGROK_URL)
# BACKEND_URL=https://tu-backend.onrender.com

# Frontend URL (CORS + redirect URLs de MercadoPago)
# Local: http://localhost:5173
# Producción: https://tu-frontend.vercel.app (o donde esté desplegado)
FRONTEND_URL=http://localhost:5173

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=tu_contraseña_de_app
ADMIN_EMAIL=admin@tudominio.com

# MongoDB (local o Atlas)
# Local: mongodb://localhost:27017/lataller
# Producción: mongodb+srv://usuario:password@cluster.mongodb.net/lataller
MONGODB_URI=mongodb://localhost:27017/lataller

# Sync a Atlas (opcional, si ATLAS_URI no existe se desactiva)
ATLAS_URI=mongodb+srv://usuario:password@cluster.mongodb.net/lataller?retryWrites=true&w=majority

# Admin Panel
JWT_SECRET=un_secreto_jwt_largo_y_seguro_cambiar_esto
ADMIN_PASSWORD_HASH=$2b$10$HASH_GENERADO_CON_hashPassword.js
